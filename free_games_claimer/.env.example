# =============================================================================
# Free Games Claimer Remaster – Environment Configuration
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:          cp .env.example .env
#   2. Fill in your values below (uncomment lines by removing the '#')
#   3. Run:                     docker compose up -d --build
#
# The .env file is gitignored and will NOT be pushed to the repository.
# Lines starting with '#' are comments and are ignored.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DISPLAY / VNC  –  Control the virtual browser window inside Docker
# ─────────────────────────────────────────────────────────────────────────────

# Show the browser window inside VNC (1 = yes, 0 = headless / no window)
SHOW=1

# Resolution of the virtual display inside Docker
WIDTH=1080
HEIGHT=720

# Port to access noVNC web client (open http://localhost:7080 in your browser)
NOVNC_PORT=7080

# The IP address or Hostname displayed in Discord/Apprise notifications 
# Change this if you run the bot on a remote server/NAS and 'localhost' doesn't work.
# VNC_IP=192.168.1.100

# Optional: Set a password for VNC access (empty = no password)
# VNC_PASSWORD=


# ─────────────────────────────────────────────────────────────────────────────
# SCHEDULER  –  How often the bot checks for new free games
# ─────────────────────────────────────────────────────────────────────────────

# Interval in hours between automatic claiming runs (default: every 12 hours)
# SCHEDULER_HOURS=12


# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS  –  Get alerts when games are claimed or errors occur
# ─────────────────────────────────────────────────────────────────────────────

# Discord webhook URL — the bot sends messages here about claimed games
# Create one in Discord: Server Settings → Integrations → Webhooks → New Webhook
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Alternative: Apprise URL for Telegram, Slack, Email, etc.
# See https://github.com/caronc/apprise for supported services
# NOTIFY=tgram://bottoken/ChatID

# Fine-tune which notifications you receive (1 = enabled, 0 = disabled):
# NOTIFY_SUMMARY=1           # Summary of all claimed games after each run
# NOTIFY_ERRORS=1            # Critical errors / module crashes
# NOTIFY_CLAIM_FAILS=1       # Individual claim failures (e.g. "could not click button")
# NOTIFY_LOGIN_REQUEST=1     # Alert when manual VNC login is needed


# ─────────────────────────────────────────────────────────────────────────────
# DEFAULT CREDENTIALS  –  Used by ALL stores unless overridden below
# ─────────────────────────────────────────────────────────────────────────────
# If you use the same email/password for every store, set them here.
# Store-specific values below will take priority over these defaults.

# EMAIL=
# PASSWORD=


# ─────────────────────────────────────────────────────────────────────────────
# EPIC GAMES  –  Claims weekly free games from the Epic Games Store
# ─────────────────────────────────────────────────────────────────────────────

# EG_EMAIL=your@email.com
# EG_PASSWORD=your_password

# 2FA / MFA key (the "Manual Entry Key" from Epic's authenticator setup)
# EG_OTPKEY=

# Parental Controls PIN (if you have it enabled on your Epic account)
# EG_PARENTALPIN=


# ─────────────────────────────────────────────────────────────────────────────
# PRIME GAMING (Amazon)  –  Claims monthly free games from Prime Gaming
# ─────────────────────────────────────────────────────────────────────────────

# PG_EMAIL=your@email.com
# PG_PASSWORD=your_password

# Amazon 2FA key (from "Login & Security → 2-Step Verification → Authenticator App")
# PG_OTPKEY=

# Force re-check games that are already marked as "claimed" in the database
# Useful if you suspect some were missed or codes were not extracted properly
# PG_FORCE_CHECK_COLLECTED=0

# Try to automatically redeem keys on external stores (experimental)
# PG_REDEEM=0

# Also try to claim DLCs, not just base games (experimental)
# PG_CLAIMDLC=0


# ─────────────────────────────────────────────────────────────────────────────
# GOG  –  Claims periodic free game giveaways from GOG.com
# ─────────────────────────────────────────────────────────────────────────────

# GOG_EMAIL=your@email.com
# GOG_PASSWORD=your_password

# Keep newsletter subscription after claiming (0 = unsubscribe, 1 = keep)
# GOG_NEWSLETTER=0

# Force re-redeem old GOG codes from Prime Gaming even if already processed
# GOG_FORCE_REDEEM=0

# Automatically consume backup codes for GOG 2FA (if enabled)
# GOG_OTP_ENABLE=false
# GOG_OTP_CODES=CODE1,CODE2,CODE3

# ─────────────────────────────────────────────────────────────────────────────
# STEAM  –  Claims free-to-keep games from Steam
# ─────────────────────────────────────────────────────────────────────────────

# STEAM_USERNAME=your_username
# STEAM_PASSWORD=your_password


# ─────────────────────────────────────────────────────────────────────────────
# MODULE SELECTION & ADVANCED
# ─────────────────────────────────────────────────────────────────────────────

# If empty, default stores (steam, epic, prime, gog) will run, EXCLUDING gamerpower.
# STORES=steam,epic,prime,gog

# Clear database memory for recent game claims upon startup.
# Useful if games were falsely marked as 'claimed' or 'already redeemed', 
# and you want the bot to try claiming them again.
# Set to 'true' to automatically delete all claims recorded in the last 7 days.
# RESET_DB_GAMES=false
# --- Fanatical Configuration (via GamerPower) ---
# Some GamerPower giveaways redirect to Fanatical.com.
# Fanatical giveaways require logging into Fanatical and having your Steam account linked globally!
# (To use Fanatical, make sure you ALSO ADD 'gamerpower' to your STORES list above!)
#
# FANATICAL_ENABLE=false
# FANATICAL_EMAIL=your_fanatical@email.com
# FANATICAL_PASSWORD=your_password

# --- Alienware Arena Configuration (via GamerPower) ---
# Many GamerPower giveaways redirect to alienwarearena.com for key retrieval.
# Since Alienware Arena requires ARP points to claim keys and uses heavy 
# CAPTCHAs, this module operates in **notify-only** mode. When enabled,
# you will receive a Discord/Apprise alert to claim the key manually.
#
# ALIENWARE_ENABLE=false

# --- Itch.io Configuration (via GamerPower) ---
# Some GamerPower giveaways redirect to itch.io for free game claiming.
# Requires a free itch.io account.
#
# ITCHIO_ENABLE=false
# ITCHIO_EMAIL=your_itchio@email.com
# ITCHIO_PASSWORD=your_password

# --- IndieGala Configuration (via GamerPower) ---
# Some GamerPower giveaways redirect to indiegala.com for free DRM-free games.
# Requires a free IndieGala account.
#
# INDIEGALA_ENABLE=false
# INDIEGALA_EMAIL=your_indiegala@email.com
# INDIEGALA_PASSWORD=your_password

# --- Other/Unknown Stores (via GamerPower) ---
# If a giveaway points to a site not explicitly supported above (e.g. MMOBomb),
# by default the bot skips it. Set to true if you want the bot to open these
# in the browser anyway (you will have to claim them manually via VNC).
#
# UNKNOWN_STORES_ENABLE=false


# Browser profile directory (stores cookies and session data between restarts)
# BROWSER_DIR=data/browser

# Enable verbose debug logging (shows every action the bot takes)
# DEBUG=0

# Dry run mode — go through all steps but don't actually click "claim" buttons
# DRYRUN=0
